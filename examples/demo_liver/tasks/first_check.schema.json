{
    "type": "object",
    "properties": {
        "is_good": {
            "type": "boolean",
            "description": "Whether the study is suitable for the trial"
        }
    },
    "required": ["is_good"],
    "if": {
        "properties": { "is_good": { "const": true } }
    },
    "then": {
        "properties": {
            "study_type": {
                "type": "string",
                "enum": ["CT-archive", "CT", "MRI", "CT-AG", "MRI-AG", "PDCT-AG"],
                "description": "Modality type"
            },
            "best_series": {
                "type": "string",
                "pattern": "^[0-9.]+$",
                "description": "DICOM UID of the best series for metastasis visualization"
            }
        },
        "required": ["study_type", "best_series"]
    },
    "unevaluatedProperties": false
}
