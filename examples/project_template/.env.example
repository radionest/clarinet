# ============================================================
# Clarinet research project — environment variables
# Copy this file to .env and fill in the values for your server
# ============================================================

# --- Server ---
CLARINET_PORT=8111

# --- Database (PostgreSQL) ---
CLARINET_DATABASE_NAME=clarinet_my_project
CLARINET_DATABASE_HOST=localhost
CLARINET_DATABASE_PORT=5432
CLARINET_DATABASE_LOGIN=clarinet
CLARINET_DATABASE_PASSWORD=

# --- Security ---
CLARINET_SECRET_KEY=
CLARINET_ADMIN_PASSWORD=

# --- Storage ---
CLARINET_STORAGE_PATH=./data

# --- RabbitMQ (pipeline tasks) ---
CLARINET_RABBITMQ_HOST=
CLARINET_RABBITMQ_LOGIN=clarinet
CLARINET_RABBITMQ_PASSWORD=

# --- DICOM (local node) ---
CLARINET_DICOM_AET=CLARINET

# --- PACS server ---
CLARINET_PACS_AET=ORTHANC
CLARINET_PACS_HOST=
CLARINET_PACS_PORT=4242
